{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "notesync-ai",
  "version": "0.1.0",
  "identifier": "com.tauri-app.notesync-ai",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "notesync-ai",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "externalBin": [
      "binaries/api" 
    ],
    "active": true,
    "targets": "all",
    "resources": [
      "bundle-resources/notesync-backend.exe"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
